# Application
NODE_ENV=development
PORT=3000

# LLM Providers
LLM_PROVIDER=openai       # openai | anthropic

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Worker
WORKER_CONCURRENCY=5
WORKER_POLL_INTERVAL_MS=1000
